rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    // Replace with your real account email(s) if needed.
    function isLibraryAdmin() {
      return signedIn()
        && request.auth.token.email in ['imad@gmail.com'];
    }

    match /songs/{songId} {
      allow read: if true;
      allow create: if signedIn();
      allow update, delete: if signedIn();

      match /comments/{commentId} {
        allow read: if true;
        allow create, update, delete: if signedIn();
      }

      match /ratings/{uid} {
        allow read: if true;
        allow create, update: if signedIn() && request.auth.uid == uid;
        allow delete: if false;
      }
    }

    match /training_articles/{articleId} {
      allow read: if true;
      allow create, update, delete: if signedIn();

      match /comments/{commentId} {
        allow read: if true;
        allow create, update, delete: if signedIn();
      }

      match /ratings/{uid} {
        allow read: if true;
        allow create, update: if signedIn() && request.auth.uid == uid;
        allow delete: if false;
      }
    }

    match /chords/{chordId} {
      allow read: if true;
      allow create, update, delete: if isLibraryAdmin();
    }

    match /guitar_tones/{toneId} {
      allow read: if true;
      allow create, update, delete: if isLibraryAdmin();

      match /string_chunks/{chunkId} {
        allow read: if true;
        allow create, update, delete: if isLibraryAdmin();
      }
    }

    match /users/{uid} {
      allow read, write: if signedIn() && request.auth.uid == uid;

      match /{document=**} {
        allow read, write: if signedIn() && request.auth.uid == uid;
      }
    }

    match /public_loops/{shareId} {
      allow read: if true;
      allow create: if signedIn() && request.resource.data.ownerId == request.auth.uid;
      allow update, delete: if signedIn() && resource.data.ownerId == request.auth.uid;

      match /media_chunks/{chunkId} {
        allow read: if true;
        allow create, update, delete: if signedIn()
          && get(/databases/$(database)/documents/public_loops/$(shareId)).data.ownerId == request.auth.uid;
      }
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
